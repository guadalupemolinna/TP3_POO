public class Turno {
    private String nombrePersona;
    private int hora;

    public Turno(String nombrePersona, int hora) {
        this.nombrePersona = nombrePersona;
        this.hora = hora;
    }

    public String getNombrePersona() {
        return nombrePersona;
    }

    public int getHora() {
        return hora;
    }
}



import java.util.ArrayList;

public class Cancha {
    private String nombre;
    private ArrayList<Turno> turnos;

    public Cancha(String nombre) {
        this.nombre = nombre;
        this.turnos = new ArrayList<>();
    }

    public String getNombre() {
        return nombre;
    }

    // Reservar turno
    public boolean reservarTurno(Turno t) {

        // Validar horario
        if (t.getHora() < 14 || t.getHora() > 23) {
            return false;
        }

        // Verificar si el horario ya está ocupado
        for (Turno turno : turnos) {
            if (turno.getHora() == t.getHora()) {
                return false;
            }
        }

        // Agregar turno
        turnos.add(t);
        return true;
    }

    // Cancelar turno
    public boolean cancelarTurno(int hora) {
        for (Turno turno : turnos) {
            if (turno.getHora() == hora) {
                turnos.remove(turno);
                return true;
            }
        }

        return false;
    }

    // Mostrar estado de la cancha
    public void mostrarEstado() {
        System.out.println("\n" + nombre);

        for (int i = 14; i <= 23; i++) {
            boolean ocupado = false;

            for (Turno turno : turnos) {
                if (turno.getHora() == i) {
                    System.out.println(i + ":00 - OCUPADO por " + turno.getNombrePersona());
                    ocupado = true;
                }
            }

            if (!ocupado) {
                System.out.println(i + ":00 - LIBRE");
            }
        }
    }
}


import java.util.Scanner;

public class Main {
    public static void main(String[] args) {

        Scanner scanner = new Scanner(System.in);

        // Instanciar las 3 canchas
        Cancha cancha1 = new Cancha("Cancha 1");
        Cancha cancha2 = new Cancha("Cancha 2");
        Cancha cancha3 = new Cancha("Cancha 3");

        int opcion;

        do {
            System.out.println("\n===== COMPLEJO DEPORTIVO =====");
            System.out.println("1. Ver estado de canchas");
            System.out.println("2. Registrar reserva");
            System.out.println("3. Cancelar reserva");
            System.out.println("4. Salir");
            System.out.print("Seleccione una opcion: ");

            opcion = scanner.nextInt();
            scanner.nextLine();

            switch (opcion) {

                case 1:
                    cancha1.mostrarEstado();
                    cancha2.mostrarEstado();
                    cancha3.mostrarEstado();
                    break;

                case 2:
                    System.out.print("Ingrese numero de cancha (1-3): ");
                    int numCancha = scanner.nextInt();
                    scanner.nextLine();

                    System.out.print("Ingrese nombre de la persona: ");
                    String nombre = scanner.nextLine();

                    System.out.print("Ingrese hora (14-23): ");
                    int hora = scanner.nextInt();

                    Turno nuevoTurno = new Turno(nombre, hora);

                    boolean resultado = false;

                    switch (numCancha) {
                        case 1:
                            resultado = cancha1.reservarTurno(nuevoTurno);
                            break;
                        case 2:
                            resultado = cancha2.reservarTurno(nuevoTurno);
                            break;
                        case 3:
                            resultado = cancha3.reservarTurno(nuevoTurno);
                            break;
                        default:
                            System.out.println("Cancha invalida");
                    }

                    if (resultado) {
                        System.out.println("Reserva exitosa");
                    } else {
                        System.out.println("Error: Turno ocupado o horario invalido");
                    }

                    break;

                case 3:
                    System.out.print("Ingrese numero de cancha (1-3): ");
                    int canchaCancelar = scanner.nextInt();

                    System.out.print("Ingrese hora del turno a cancelar: ");
                    int horaCancelar = scanner.nextInt();

                    boolean cancelado = false;

                    switch (canchaCancelar) {
                        case 1:
                            cancelado = cancha1.cancelarTurno(horaCancelar);
                            break;
                        case 2:
                            cancelado = cancha2.cancelarTurno(horaCancelar);
                            break;
                        case 3:
                            cancelado = cancha3.cancelarTurno(horaCancelar);
                            break;
                        default:
                            System.out.println("Cancha invalida");
                    }

                    if (cancelado) {
                        System.out.println("Reserva cancelada");
                    } else {
                        System.out.println("No existe una reserva en ese horario");
                    }

                    break;

                case 4:
                    System.out.println("Saliendo del sistema...");
                    break;

                default:
                    System.out.println("Opcion invalida");
            }

        } while (opcion != 4);

        scanner.close();
    }
}

